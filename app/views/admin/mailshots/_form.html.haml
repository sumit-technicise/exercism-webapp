= form_with(model: [:admin, mailshot]) do |form|
  - if mailshot.errors.any?
    .mb-12.text-red
      %h2
        = pluralize(mailshot.errors.count, "error")
        prohibited this mailshot from being saved:
      %ul
        - mailshot.errors.each do |error|
          %li= error.full_message

  .flex.flex-col
    .mb-12
      = form.label :slug, class: "block mb-4"
      - if mailshot.persisted? && mailshot.custom_mailer?
        = form.text_field :slug, readonly: true, class: 'w-fill'
        .text-p-small.mt-4.text-textColor6 This slug maps to a custom email template and can't be changed.
      - else
        = form.text_field :slug, list: "mailshot-slugs", class: 'w-fill'
        %datalist#mailshot-slugs
          - MailshotsMailer::CUSTOM_MAILER_SLUGS.each do |slug|
            %option{ value: slug }
        .text-p-small.mt-4.text-textColor6 Choose a custom-template slug from the list, or type a manual one for a standard content mailshot.
    .mb-12
      = form.label :subject, class: "block mb-4"
      = form.text_field :subject, class: 'w-fill'
    .mb-12
      = form.label :email_communication_preferences_key, class: "block mb-4"
      .c-select= form.select :email_communication_preferences_key, communication_preferences_keys, class: 'w-fill'
    .mb-12
      = form.label :button_text, class: "block mb-4"
      = form.text_field :button_text, class: 'w-fill'
    .mb-12
      = form.label :button_url, class: "block mb-4"
      = form.text_field :button_url, class: 'w-fill'
    .mb-12
      = form.label :content_markdown, class: "block mb-4"
      = form.text_area :content_markdown, class: 'w-fill h-[400px]'
    .mb-12
      = form.label :text_content, class: "block mb-4"
      = form.text_area :text_content, class: 'w-fill h-[400px]'

    .mb-12
      = form.submit class: "btn btn-primary"
